{
  "name": "vltk8-app",
  "version": "1.0.0",
  "description": "VLTK8 Desktop App (đóng gói từ https://vltk8.blogspot.com/)",
  "main": "main.js",
  "author": "Your Name",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.vltk8.app",
    "productName": "VLTK8",
    "files": [
      "main.js",
      "package.json",
      "build/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VLTK8"
    }
  }
}
